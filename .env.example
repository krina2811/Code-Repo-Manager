# Copy this file to .env and fill in your values
# cp .env.example .env

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=code_repo_manager
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here

# JWT — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-generate-a-strong-random-key

# API URL for Streamlit frontend
API_BASE_URL=http://localhost:8000

# Logging — set true for local dev to write logs/app.log, leave unset for production
# LOG_TO_FILE=true

# Backup — set true for local dev only, leave unset for production
# Production backup should use S3/MinIO (future implementation)
# ENABLE_BACKUP=true
# BACKUP_DIR=/your/local/backup/path

# Optional — Anthropic Claude API (for cloud LLM instead of Ollama)
# ANTHROPIC_API_KEY=sk-ant-...
