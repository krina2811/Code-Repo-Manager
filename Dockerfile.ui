# Same base image as API
FROM python:3.11-slim

WORKDIR /app

# Streamlit doesn't need gcc/libpq, lighter install
RUN apt-get update && apt-get install -y \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY . .

# Streamlit runs on port 8501
EXPOSE 8501

# Streamlit needs these flags for running inside Docker:
#   --server.address=0.0.0.0  → accept connections from outside container
#   --server.headless=true    → don't try to open a browser
CMD ["streamlit", "run", "ui/app.py", \
     "--server.port=8501", \
     "--server.address=0.0.0.0", \
     "--server.headless=true"]
